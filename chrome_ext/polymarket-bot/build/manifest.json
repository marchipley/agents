{
  "version": "1.0.0",
  "name": "Polymarket BTC Agent",
  "description": "Personal-use Polymarket assistant with an in-page output panel and configurable agent settings.",
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "64": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://polymarket.com/*",
        "https://www.polymarket.com/*"
      ],
      "js": [
        "content_scripts/content-0.js"
      ],
      "css": []
    }
  ],
  "author": "Personal Use",
  "manifest_version": 3,
  "action": {
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "64": "icons/icon.png",
      "128": "icons/icon.png"
    },
    "default_title": "Polymarket BTC Agent"
  },
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs"
  ]
}